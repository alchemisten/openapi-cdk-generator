{
  "name": "openapi-cdk-transformer",
  "version": "0.1.0",
  "description": "Library that transforms an OpenAPI specification to Typescript code",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "format": "prettier --write \"src/**/*.ts\" \"src/**/*.js\"",
    "lint": "tslint -p tsconfig.json",
    "preversion": "npm run lint",
    "test": "jest --passWithNoTests",
    "generate-openapi": "openapi-generator-cli generate -t ./templates -i ./test/samples/petstore-v3.yaml -g typescript-axios -o sample/src/lambda/shared/generated/petstore-api --additional-properties=withInterfaces=true,typescriptThreePlus=true,withSeparateModelsAndApi=true,apiPackage=api,modelPackage=dto --skip-validate-spec"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alchemisten/openapi-cdk-generator.git"
  },
  "keywords": [
    "cdk",
    "typescript",
    "generator",
    "openapi",
    "open-api",
    "api-gateway",
    "lambda"
  ],
  "author": "Alchemisten AG",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/alchemisten/openapi-cdk-generator/issues"
  },
  "homepage": "https://github.com/alchemisten/openapi-cdk-generator#readme",
  "dependencies": {
    "@openapitools/openapi-generator-cli": "^2.2.6",
    "change-case": "^4.1.2",
    "openapi-types": "^7.0.1",
    "prettier": "^2.2.1",
    "typescript": "^4.0.5",
    "yaml": "^1.10.0"
  },
  "devDependencies": {
    "@middy/core": "^2.2.0",
    "@middy/http-json-body-parser": "^2.2.0",
    "@middy/validator": "^2.2.0",
    "@types/aws-lambda": "^8.10.76",
    "@types/jest": "^26.0.19",
    "@types/node": "^14.14.14",
    "@types/prettier": "^2.1.5",
    "@types/yaml": "^1.9.7",
    "aws-lambda": "^1.0.6",
    "jest": "^26.6.3",
    "ts-jest": "^26.4.4",
    "ts-lint": "^4.5.1",
    "ts-node": "^9.1.1"
  }
}
